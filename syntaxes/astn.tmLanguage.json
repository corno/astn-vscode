{
	"name": "astn",
	"scopeName": "source.astn",
	"patterns": [
		{
			"match": "!",
			"name": "punctuation.definition.schema.astn"
		},
		{
			"match": "#",
			"name": "punctuation.definition.compact.astn"
		},
		{
			"include": "#apostrophed-string-other"
		},
		{
			"include": "#value"
		},
		{
			"match": "[^\\s\\}]",
			"name": "invalid.illegal.unexpected-root-token.astn"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"begin": "/\\*\\*(?!/)",
					"captures": {
						"0": {
							"name": "punctuation.definition.comment.astn"
						}
					},
					"end": "\\*/",
					"name": "comment.block.documentation.astn"
				},
				{
					"begin": "/\\*",
					"captures": {
						"0": {
							"name": "punctuation.definition.comment.astn"
						}
					},
					"end": "\\*/",
					"name": "comment.block.astn"
				},
				{
					"captures": {
						"1": {
							"name": "punctuation.definition.comment.astn"
						}
					},
					"match": "(//).*$\\n?",
					"name": "comment.line.double-slash.js"
				}
			]
		},
		"constant": {
			"match": "\\b(?:true|false|null)\\b",
			"name": "constant.language.astn"
		},
		"number": {
			"match": "(?x)        # turn on extended mode\n  -?        # an optional minus\n  (?:\n    0       # a zero\n    |       # ...or...\n    [1-9]   # a 1-9 character\n    \\d*     # followed by zero or more digits\n  )\n  (?:\n    (?:\n      \\.    # a period\n      \\d+   # followed by one or more digits\n    )?\n    (?:\n      [eE]  # an e character\n      [+-]? # followed by an option +/-\n      \\d+   # followed by one or more digits\n    )?      # make exponent optional\n  )?        # make decimal portion optional",
			"name": "constant.numeric.astn"
		},
		"list": {
			"begin": "\\[",
			"beginCaptures": {
				"0": {
					"name": "punctuation.definition.list.begin.astn"
				}
			},
			"end": "\\]",
			"endCaptures": {
				"0": {
					"name": "punctuation.definition.list.end.astn"
				}
			},
			"name": "meta.structure.list.astn",
			"patterns": [
				{
					"include": "#value"
				},
				{
					"match": ",",
					"name": "punctuation.separator.list.astn"
				},
				{
					"match": "[^\\s\\]]",
					"name": "invalid.illegal.expected-list-separator-or-end.astn"
				}
			]
		},
		"arraytype": {
			"begin": "\\<",
			"beginCaptures": {
				"0": {
					"name": "punctuation.definition.arraytype.begin.astn"
				}
			},
			"end": "\\>",
			"endCaptures": {
				"0": {
					"name": "punctuation.definition.arraytype.end.astn"
				}
			},
			"name": "meta.structure.arraytype.astn",
			"patterns": [
				{
					"include": "#value"
				},
				{
					"match": ",",
					"name": "punctuation.separator.arraytype.astn"
				},
				{
					"match": "[^\\s\\]]",
					"name": "invalid.illegal.expected-arraytype-separator-or-end.astn"
				}
			]
		},
		"dictionary": {
			"begin": "\\{",
			"beginCaptures": {
				"0": {
					"name": "punctuation.definition.dictionary.begin.astn"
				}
			},
			"end": "\\}",
			"endCaptures": {
				"0": {
					"name": "punctuation.definition.dictionary.end.astn"
				}
			},
			"name": "meta.structure.dictionary.astn",
			"patterns": [
				{
					"include": "#apostrophed-key-in-dictionary"
				},
				{
					"include": "#quoted-key-in-dictionary"
				},
				{
					"include": "#value"
				},
				{
					"match": ",",
					"name": "punctuation.separator.dictionary.astn"
				},
				{
					"match": "[^\\s\\}]",
					"name": "invalid.illegal.expected-dictionary-separator-or-end.astn"
				}
			]
		},
		"type": {
			"begin": "\\(",
			"beginCaptures": {
				"0": {
					"name": "punctuation.definition.type.begin.astn"
				}
			},
			"end": "\\)",
			"endCaptures": {
				"0": {
					"name": "punctuation.definition.type.end.astn"
				}
			},
			"name": "meta.structure.type.astn",
			"patterns": [
				{
					"include": "#apostrophed-key-in-type"
				},
				{
					"include": "#quoted-key-in-type"
				},
				{
					"include": "#value"
				},
				{
					"match": ",",
					"name": "punctuation.separator.type.astn"
				},
				{
					"match": "[^\\s\\}]",
					"name": "invalid.illegal.expected-type-separator-or-end.astn"
				}
			]
		},
		"quoted-value": {
			"begin": "\"",
			"beginCaptures": {
				"0": {
					"name": "punctuation.definition.string.quote.begin.astn"
				}
			},
			"end": "\"",
			"endCaptures": {
				"0": {
					"name": "punctuation.definition.string.quote.end.astn"
				}
			},
			"name": "string.quoted.double.astn",
			"patterns": [
				{
					"include": "#stringcontent"
				}
			]
		},
		"apostrophed-value": {
			"begin": "'",
			"beginCaptures": {
				"0": {
					"name": "punctuation.support.type.apostrophed-value.other.astn"
				}
			},
			"end": "'",
			"endCaptures": {
				"0": {
					"name": "punctuation.support.type.apostrophed-value.other.astn"
				}
			},
			"name": "string.astn support.type.apostrophed-string.other.astn",
			"patterns": [
				{
					"include": "#stringcontent"
				}
			]
		},
		"apostrophed-string-other": {
			"begin": "'",
			"beginCaptures": {
				"0": {
					"name": "punctuation.support.type.apostrophed-string.other.astn"
				}
			},
			"end": "'",
			"endCaptures": {
				"0": {
					"name": "punctuation.support.type.apostrophed-string.other.astn"
				}
			},
			"name": "string.astn support.type.apostrophed-string.other.astn",
			"patterns": [
				{
					"include": "#stringcontent"
				}
			]
		},
		"quoted-tagged-union": {
			"begin": "(\\|)\\s*(\")",
			"beginCaptures": {
				"1": {
					"name": "punctuation.separator.other.tagged-union.astn"
				},
				"2": {
					"name": "punctuation.definition.string.quote.begin.astn"
				}
			},
			"end": "\"",
			"endCaptures": {
				"0": {
					"name": "punctuation.definition.string.quote.end.astn"
				}
			},
			"name": "keyword.operator.logical.tagged-union.astn",
			"patterns": [
				{
					"include": "#stringcontent"
				}
			]
		},
		"apostrophed-tagged-union": {
			"begin": "(\\|)\\s*(')",
			"beginCaptures": {
				"1": {
					"name": "punctuation.separator.other.tagged-union.astn"
				},
				"2": {
					"name": "punctuation.support.type.apostrophed-string.tagged-union-option.astn"
				}
			},
			"end": "'",
			"endCaptures": {
				"0": {
					"name": "punctuation.support.type.apostrophed-string.tagged-union-option.astn"
				}
			},
			"name": "keyword.operator.logical.tagged-union.astn",
			"patterns": [
				{
					"include": "#stringcontent"
				}
			]
		},
		"quoted-key-in-dictionary": {
			"begin": "\"",
			"beginCaptures": {
				"0": {
					"name": "punctuation.definition.string.quote.begin.astn"
				}
			},
			"end": "(\")\\s*(:)",
			"endCaptures": {
				"1": {
					"name": "punctuation.definition.string.quote.end.astn"
				},
				"2": {
					"name": "punctuation.definition.colon.astn"
				}
			},
			"name": "string.quoted.single.astn",
			"patterns": [
				{
					"include": "#stringcontent"
				}
			]
		},
		"apostrophed-key-in-dictionary": {
			"begin": "'",
			"beginCaptures": {
				"0": {
					"name": "punctuation.support.type.apostrophed-key-in-dictionary.other.astn"
				}
			},
			"end": "(')\\s*(:)",
			"endCaptures": {
				"1": {
					"name": "punctuation.support.type.apostrophed-key-in-dictionary.other.astn"
				},
				"2": {
					"name": "punctuation.separator.key-value.astn"
				}
			},
			"name": "variable.other.key-in-dictionary.astn",
			"patterns": [
				{
					"include": "#stringcontent"
				}
			]
		},
		"quoted-key-in-type": {
			"match": "(\")[^\"]*(\")\\s*(:)",
			"captures": {
				"1": {
					"name": "punctuation.definition.string.quoted-key-in-type.begin.astn"
				},
				"2": {
					"name": "punctuation.definition.string.quoted-key-in-type.end.astn"
				},
				"3": {
					"name": "punctuation.definition.colon.astn"
				}
			},
			"name": "keyword.other.quoted-key-in-type.astn"
		},
		"apostrophed-key-in-type": {
			"match": "(')[^\"]*(')\\s*(:)",
			"captures": {
				"1": {
					"name": "punctuation.definition.string.apostrophed-key-in-type.begin.astn"
				},
				"2": {
					"name": "punctuation.definition.string.apostrophed-key-in-type.end.astn"
				},
				"3": {
					"name": "punctuation.definition.colon.astn"
				}
			},
			"name": "keyword.other.apostrophed-key-in-type.astn"
		},
		"stringcontent": {
			"patterns": [
				{
					"match": "(?x)                # turn on extended mode\n  \\\\                # a literal backslash\n  (?:               # ...followed by...\n    [\"\\\\/bfnrt]     # one of these characters\n    |               # ...or...\n    u               # a u\n    [0-9a-fA-F]{4}) # and four hex digits",
					"name": "constant.character.escape.astn"
				},
				{
					"match": "\\\\.",
					"name": "invalid.illegal.unrecognized-string-escape.astn"
				}
			]
		},
		"value": {
			"patterns": [
				{
					"include": "#constant"
				},
				{
					"include": "#number"
				},
				{
					"include": "#list"
				},
				{
					"include": "#arraytype"
				},
				{
					"include": "#dictionary"
				},
				{
					"include": "#type"
				},
				{
					"include": "#comments"
				},
				{
					"include": "#apostrophed-tagged-union"
				},
				{
					"include": "#quoted-tagged-union"
				},
				{
					"include": "#quoted-value"
				},
				{
					"include": "#apostrophed-value"
				}
			]
		}
	}
}